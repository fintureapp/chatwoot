<div>
  <div class="flex flex-col">
    <% CaptainModelsField::FEATURE_KEYS.each do |feature_key| %>
      <% choice = field.selected_choice(feature_key) %>
      <div class="flex items-center gap-3 py-2.5 border-b border-n-weak last:border-b-0">
        <span class="text-sm text-n-slate-11 w-44 shrink-0"><%= feature_key.titleize %></span>
        <% if choice %>
          <%= render 'fields/captain_models_field/provider_badge', model: choice %>
          <span class="text-sm font-medium text-n-slate-12"><%= choice[:name] %></span>
          <span class="font-mono text-xs text-n-slate-10"><%= choice[:id] %></span>
        <% else %>
          <span class="inline-flex items-center h-6 px-2 rounded-md text-xs font-medium bg-n-slate-3 text-n-slate-11">Default</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
