<% provider_color = { 'openai' => 'bg-n-teal-3 text-n-teal-11', 'anthropic' => 'bg-n-amber-3 text-n-amber-11', 'gemini' => 'bg-n-iris-3 text-n-iris-11' }[model[:provider].to_s] || 'bg-n-slate-4 text-n-slate-11' %>
<% provider_icon = { 'openai' => 'icon-openai', 'anthropic' => 'icon-anthropic', 'gemini' => 'icon-gemini' }[model[:provider].to_s] %>
<span class="flex items-center justify-center h-5 w-5 shrink-0 rounded <%= provider_color %>" title="<%= CaptainModelsField.provider_name(model[:provider]) %>">
  <% if provider_icon %>
    <svg class="w-3 h-3" width="12" height="12"><use xlink:href="#<%= provider_icon %>" /></svg>
  <% else %>
    <span class="text-xxs font-semibold"><%= CaptainModelsField.provider_name(model[:provider])[0] %></span>
  <% end %>
</span>
