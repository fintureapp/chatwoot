<div class="w-full space-y-6">
  <% regular_features, premium_features = SuperAdmin::AccountFeaturesHelper.partition_features(field.data) %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-px">
    <% regular_features.each do |key_array, val| %>
      <% _feature_key, display_name = key_array %>
      <div class="flex items-center justify-between gap-3 py-2.5 border-b border-n-weak">
        <span class="text-sm <%= val.present? ? 'text-n-slate-12' : 'text-n-slate-11' %>"><%= display_name %></span>
        <span class="relative inline-flex h-4 w-7 shrink-0 rounded-full transition-colors <%= val.present? ? 'bg-n-brand' : 'bg-n-slate-6' %>">
          <span class="absolute top-0.5 h-3 w-3 rounded-full bg-n-solid-1 shadow-sm transition-all <%= val.present? ? 'left-3.5' : 'left-0.5' %>"></span>
        </span>
      </div>
    <% end %>
  </div>

  <% if premium_features.any? %>
    <div>
      <p class="text-xs font-medium uppercase tracking-wide text-n-slate-10 mb-2">Premium</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-px">
        <% premium_features.each do |key_array, val| %>
          <% _feature_key, display_name = key_array %>
          <div class="flex items-center justify-between gap-3 py-2.5 border-b border-n-weak">
            <span class="flex items-center gap-1.5 text-sm <%= val.present? ? 'text-n-slate-12' : 'text-n-slate-11' %>">
              <svg class="text-n-amber-11" width="13" height="13"><use xlink:href="#icon-lock-line" /></svg>
              <%= display_name %>
            </span>
            <span class="relative inline-flex h-4 w-7 shrink-0 rounded-full transition-colors <%= val.present? ? 'bg-n-brand' : 'bg-n-slate-6' %>">
              <span class="absolute top-0.5 h-3 w-3 rounded-full bg-n-solid-1 shadow-sm transition-all <%= val.present? ? 'left-3.5' : 'left-0.5' %>"></span>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
