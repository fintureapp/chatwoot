<div class="field-unit__field">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-3">
    <% JSON.parse(field.to_s).each do |key, val| %>
      <div class="flex flex-col gap-1.5">
        <label class="text-xs font-medium text-n-slate-11"><%= key.to_s.humanize %></label>
        <%= number_field "account[limits]", key, value: val, placeholder: 'Default',
          class: "w-full h-9 rounded-lg bg-n-solid-1 text-sm text-n-slate-12 px-3 outline outline-1 -outline-offset-1 outline-n-weak hover:outline-n-slate-6 focus:outline-2 focus:outline-n-brand transition-all duration-200" %>
      </div>
    <% end %>
  </div>
</div>
