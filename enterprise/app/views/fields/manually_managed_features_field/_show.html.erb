<%
  selected_features = field.selected_features
  all_feature_display_names = SuperAdmin::AccountFeaturesHelper.feature_display_names
%>

<% if selected_features.present? %>
  <p class="text-xs text-n-slate-10 mb-3">Features that stay enabled even when the account&rsquo;s plan is downgraded.</p>
  <div class="flex flex-wrap gap-2">
    <% selected_features.each do |feature| %>
      <span class="inline-flex items-center gap-1.5 h-6 px-2 rounded-md text-xs font-medium outline outline-1 -outline-offset-1 bg-n-teal-2 outline-n-teal-4 text-n-teal-11">
        <span class="h-1.5 w-1.5 rounded-full bg-n-teal-9"></span><%= all_feature_display_names[feature] || feature.humanize %>
      </span>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-n-slate-10">No manually managed features configured.</p>
<% end %>
