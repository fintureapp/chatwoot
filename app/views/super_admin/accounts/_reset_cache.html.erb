<div class="border-t border-n-weak pt-5">
  <%= form_for([:reset_cache, namespace, page.resource], method: :post, html: { class: "form flex items-start justify-between gap-4" }) do |f| %>
    <div>
      <h3 class="text-sm font-medium text-n-slate-12">Reset frontend cache</h3>
      <p class="mt-0.5 text-xs text-n-slate-10">Clears the IndexedDB cache keys from Redis. The next load fetches fresh data from the backend.</p>
    </div>
    <%= f.submit 'Reset frontend cache',
      class: "shrink-0 inline-flex items-center h-9 px-4 rounded-lg bg-n-solid-1 text-n-slate-12 text-sm font-medium outline outline-1 outline-n-container hover:bg-n-alpha-1 transition-all cursor-pointer" %>
  <% end %>
</div>
