<% if ENV.fetch('ENABLE_ACCOUNT_SEEDING', !Rails.env.production?) %>
  <%= form_for([:seed, namespace, page.resource], method: :post, html: { class: "form flex items-start justify-between gap-4" }) do |f| %>
    <div>
      <h3 class="text-sm font-medium text-n-slate-12">Generate seed data</h3>
      <p class="mt-0.5 text-xs text-n-slate-10">Populates demo data for this account. Clears all existing data in the account first.</p>
    </div>
    <%= f.submit 'Generate seed data',
      class: "shrink-0 inline-flex items-center h-9 px-4 rounded-lg bg-n-solid-1 text-n-slate-12 text-sm font-medium outline outline-1 outline-n-container hover:bg-n-alpha-1 transition-all cursor-pointer" %>
  <% end %>
<% end %>
