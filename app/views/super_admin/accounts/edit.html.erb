<%# Super admin account edit. %>
<% content_for(:title) { t("administrate.actions.edit_resource", name: page.page_title) } %>
<% account = page.resource %>
<% initial = account.name.to_s.strip.first&.upcase.presence || '#' %>

<div class="bg-n-background min-h-full px-6 py-6 lg:px-8">
  <div class="max-w-5xl mx-auto space-y-4">
    <section class="rounded-xl bg-n-solid-2 outline outline-1 -outline-offset-1 outline-n-container px-6 py-5 flex items-center justify-between gap-4">
      <div class="flex items-center gap-3.5 min-w-0">
        <div class="h-11 w-11 shrink-0 rounded-xl bg-n-brand/10 text-n-brand flex items-center justify-center text-base font-semibold">
          <%= initial %>
        </div>
        <div class="min-w-0">
          <p class="text-xs font-medium uppercase tracking-wide text-n-slate-10">Editing account</p>
          <h1 class="text-lg font-semibold text-n-slate-12 truncate" id="page-title"><%= account.name %></h1>
        </div>
      </div>
      <% if accessible_action?(account, :show) %>
        <%= link_to "Cancel", [namespace, account],
          class: "shrink-0 inline-flex items-center h-9 px-4 rounded-lg bg-n-solid-1 text-n-slate-12 text-sm font-medium outline outline-1 outline-n-container hover:bg-n-alpha-1 transition-all no-underline" %>
      <% end %>
    </section>

    <%= render "form", page: page %>
  </div>
</div>
