<div class="field-unit__label">
  <%= f.label field.attribute, class: "block text-sm font-medium text-n-slate-12" %>
</div>
<div class="field-unit__field">
  <div class="relative inline-block w-full max-w-xs">
    <%= f.select(
      field.attribute,
      options_for_select(field.selectable_options, field.data),
      { include_blank: field.include_blank_option },
      class: "cw-native-select !appearance-none !bg-none w-full h-9 rounded-lg !bg-n-solid-1 text-sm text-n-slate-12 !pl-3 !pr-9 outline outline-1 -outline-offset-1 outline-n-weak hover:outline-n-slate-6 focus:outline-2 focus:outline-n-brand transition-all duration-200"
    ) %>
    <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-n-slate-10" width="14" height="14" viewBox="0 0 20 20" fill="none">
      <path d="M5.5 7.5 10 12l4.5-4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
</div>
